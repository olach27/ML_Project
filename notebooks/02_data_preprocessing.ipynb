    "# Cell 8 — ÉTAPE 6 : Encodage des variables catégorielles\n",
    "print('ÉTAPE 6 — ENCODAGE DES VARIABLES CATÉGORIELLES')\n",
    "print('=' * 55)\n",
    "\n",
    "# ─── 6a. Ordinal Encoding (features avec ordre naturel) ───\n",
    "print('--- 6a. Ordinal Encoding ---')\n",
    "\n",
    "ordinal_mappings = {\n",
    "    'AgeCategory': {\n",
    "        '18-24': 0, '25-34': 1, '35-44': 2,\n",
    "        '45-54': 3, '55-64': 4, '65+': 5, 'Inconnu': -1\n",
    "    },\n",
    "    'SpendingCategory': {\n",
    "        'Low': 0, 'Medium': 1, 'High': 2, 'VIP': 3\n",
    "    },\n",
    "    'PreferredTimeOfDay': {\n",
    "        'Matin': 0, 'Midi': 1, 'Après-midi': 2, 'Soir': 3, 'Nuit': 4\n",
    "    },\n",
    "    'LoyaltyLevel': {\n",
    "        'Nouveau': 0, 'Jeune': 1, 'Établi': 2, 'Ancien': 3, 'Inconnu': -1\n",
    "    },\n",
    "    'ChurnRiskCategory': {\n",
    "        'Faible': 0, 'Moyen': 1, 'Élevé': 2, 'Critique': 3\n",
    "    },\n",
    "    'BasketSizeCategory': {\n",
    "        'Petit': 0, 'Moyen': 1, 'Grand': 2, 'Inconnu': -1\n",
    "    },\n",
    "}\n",
    "\n",
    "for col, mapping in ordinal_mappings.items():\n",
    "    if col in df.columns:\n",
    "        df[col] = df[col].map(mapping).fillna(-1).astype(int)\n",
    "        print(f'  ✅ {col}')\n",
    "\n",
    "print()\n",
    "\n",
    "# ─── 6b. One-Hot Encoding (features nominales) ───\n",
