    "# Cell 6 — ÉTAPE 4 : Feature engineering depuis LastLoginIP\n",
    "print('ÉTAPE 4 — FEATURE ENGINEERING : LastLoginIP')\n",
    "print('=' * 55)\n",
    "\n",
    "print('Exemples d\\'adresses IP :')\n",
    "print(df['LastLoginIP'].head(5).tolist())\n",
    "\n",
    "def is_private_ip(ip_str):\n",
    "    \"\"\"Retourne 1 si IP privée (réseau local), 0 sinon.\"\"\"\n",
    "    try:\n",
    "        return int(ipaddress.ip_address(str(ip_str)).is_private)\n",
    "    except Exception:\n",
    "        return np.nan\n",
    "\n",
    "def first_octet(ip_str):\n",
    "    \"\"\"Retourne le premier octet de l'IP (classe réseau).\"\"\"\n",
    "    try:\n",
    "        return int(str(ip_str).split('.')[0])\n",
    "    except Exception:\n",
    "        return np.nan\n",
    "\n",
    "df['IP_IsPrivate']  = df['LastLoginIP'].apply(is_private_ip)\n",
    "df['IP_FirstOctet'] = df['LastLoginIP'].apply(first_octet)\n",
    "\n",
    "print(f'\\nIP_IsPrivate  — distribution :')\n",
    "print(df['IP_IsPrivate'].value_counts())\n",
    "print(f'\\nIP_FirstOctet — statistiques :')\n",
    "print(df['IP_FirstOctet'].describe().round(2))\n",
    "\n",
    "df.drop(columns=['LastLoginIP'], inplace=True)\n",
    "print(f'\\n✅ LastLoginIP supprimée → IP_IsPrivate, IP_FirstOctet. Shape : {df.shape}')"
   ]
