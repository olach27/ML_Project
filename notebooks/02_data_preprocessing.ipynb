    "for i in range(len(cols)):\n",
    "    for j in range(i+1, len(cols)):\n",
    "        if corr_mat.iloc[i, j] > 0.8:\n",
    "            high_corr_pairs.append({\n",
    "                'Feature 1':   cols[i],\n",
    "                'Feature 2':   cols[j],\n",
    "                'Correlation': round(corr_mat.iloc[i, j], 3)\n",
    "            })\n",
    "\n",
    "hc_df = pd.DataFrame(high_corr_pairs).sort_values('Correlation', ascending=False)\n",
    "print(f'Paires fortement corrélées (|r| > 0.8) : {len(hc_df)}')\n",
    "display(hc_df)\n",
    "\n",
    "# Décision : supprimer les colonnes redondantes (garder celle avec le plus de sens métier)\n",
    "cols_to_drop = [\n",
    "    'UniqueInvoices',          # Corrélé à 1.0 avec Frequency\n",
    "    'UniqueDescriptions',      # Corrélé à 1.0 avec UniqueProducts\n",
    "    'CancelledTransactions',   # Corrélé à 1.0 avec NegativeQuantityCount\n",
    "    'MonetaryMin',             # Redondant avec MonetaryMax, MonetaryStd\n",
    "    'MinQuantity',             # Redondant avec MaxQuantity, MonetaryStd\n",
    "    'AvgLinesPerInvoice',      # Corrélé à 0.96 avec AvgProductsPerTransaction\n",
    "]\n",
    "\n",
    "# Ne supprimer que celles qui existent encore\n",
    "cols_to_drop = [c for c in cols_to_drop if c in df.columns]\n",
    "df.drop(columns=cols_to_drop, inplace=True)\n",
    "\n",
    "print(f'\\n✅ Supprimées (multicolinéarité) : {cols_to_drop}')\n",
    "print(f'   Shape après : {df.shape}')"
   ]
  },
