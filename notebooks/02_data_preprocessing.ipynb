    "# Cell 3 — ÉTAPE 1 : Suppression des features à variance nulle\n",
    "print('ÉTAPE 1 — SUPPRESSION DES FEATURES INUTILES')\n",
    "print('=' * 55)\n",
    "\n",
    "# Identifier toutes les colonnes avec une seule valeur unique\n",
    "constant_cols = [col for col in df.columns if df[col].nunique(dropna=False) == 1]\n",
    "print(f'Colonnes constantes trouvées : {constant_cols}')\n",
    "\n",
    "for col in constant_cols:\n",
    "    print(f'  → {col} : valeur unique = \"{df[col].iloc[0]}\"')\n",
    "\n",
    "df.drop(columns=constant_cols, inplace=True)\n",
    "print(f'\\n✅ Supprimées : {constant_cols}')\n",
    "print(f'   Shape après suppression : {df.shape}')"
   ]
