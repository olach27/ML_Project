    "# Cell 5 — ÉTAPE 3 : Parsing de RegistrationDate\n",
    "print('ÉTAPE 3 — PARSING DE REGISTRATIONDATE')\n",
    "print('=' * 55)\n",
    "\n",
    "# Le dataset contient des formats mixtes : DD/MM/YY, YYYY-MM-DD, MM/DD/YYYY\n",
